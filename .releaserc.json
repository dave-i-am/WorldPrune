{
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      { "changelogFile": "CHANGELOG.md" }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "sed -i 's/version = \"[^\"]*\"/version = \"${nextRelease.version}\"/' build.gradle.kts && ./gradlew shadowJar --no-daemon"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md", "build.gradle.kts"],
        "message": "chore(release): ${nextRelease.version} [skip ci]"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "build/libs/world-prune-plugin-${nextRelease.version}.jar",
            "label": "WorldPrune ${nextRelease.version}"
          }
        ]
      }
    ]
  ]
}
