#!/usr/bin/env bash
# .githooks/pre-commit
# Runs compile + unit tests + Checkstyle + SpotBugs before every commit.
# Fast (~10s). Integration tests run in CI on every PR.
#
# Install once: ./gradlew installHooks

set -euo pipefail

echo "[pre-commit] Running ./gradlew check..."

if ! ./gradlew check --no-daemon; then
    echo ""
    echo "[pre-commit] BLOCKED: 'check' failed. Fix violations before committing."
    exit 1
fi

echo "[pre-commit] check passed — proceeding with commit."
